# ============================================================
# MORICHE COACHING — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Moriche Coaching"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_SINGLE_SESSION=price_...       # 5€ one-time
STRIPE_PRICE_MONTHLY_COACHING=price_...     # 15€/month
STRIPE_PRICE_TEAM_COACHING=price_...        # custom

# --- PayPal ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-webhook-id
# Set to "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# --- Discord ---
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@morichecoaching.gg

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Storage ---
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=moriche-media

# --- Admin ---
# The email of the initial admin user
ADMIN_EMAIL=admin@morichecoaching.gg
